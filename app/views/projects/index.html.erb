<% provide :title, "projects" %>

<main class="grid grid-cols-12 gap-4">
  <h1 class="text-3xl col-span-12">Projects</h1>
  <input type="text" placeholder="Search Projects" class="input input-bordered input-sm col-span-12" />
  <p class="col-span-12">
    All Projects
  </p>
  <div class="col-span-12">
    <ul>
      <% @projects.each do |project| %>
        <li>
          <a href="/" class="grid grid-cols-12 grid-rows-2 py-2 border-b border-gray-600">
            <div class="avatar col-span-2 row-span-2 grid place-content-center">
              <div class="rounded w-8 h-8">
                <img src="https://picsum.photos/300" />
              </div>
            </div>

            <div class="row-start-1 col-start-3 col-span-8">
              <%= project.name %>
            </div>

            <div class="row-start-2 col-start-3 col-span-8 text-xs text-gray-500">
              <%= project.code %>
            </div>
            <div class="grid col-span-2 row-span-2 place-content-center text-yellow-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            </div>
          </a>
        </li>
      <% end %>
    </ul>
  </div>
</main>
